@page
@model IndexModel
@using System.Text.Json
@{
    ViewData["Title"] = "Simulador de Investimento";
}

@if (!(User.Identity?.IsAuthenticated ?? false))
{
    <div class="alert alert-info mt-4" role="alert">
        <h4 class="alert-heading">Bem-vindo ao Simulador de Investimento!</h4>
        <p>Para começar a usar o simulador e salvar seu histórico de simulações, você precisa estar autenticado.</p>
        <hr />
        <p class="mb-0">
            <a asp-page="/Account/Login" class="btn btn-primary me-2">Entrar</a>
            <a asp-page="/Account/Register" class="btn btn-success">Criar Conta</a>
        </p>
    </div>
}

<div class="container py-4">
    <h1 class="mb-4">Simulador de Investimento</h1>

    <!-- INTERFACE: formulário de entrada -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form method="post" class="row g-3">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="col-md-3">
                    <label asp-for="ValorInicial" class="form-label">Valor Inicial (R$)</label>
                    <input asp-for="ValorInicial" class="form-control" type="number" step="0.01" min="0" />
                    <span asp-validation-for="ValorInicial" class="text-danger"></span>
                </div>

                <div class="col-md-3">
                    <label asp-for="TaxaJuros" class="form-label">Taxa de Juros Mensal (%)</label>
                    <input asp-for="TaxaJuros" class="form-control" type="number" step="0.01" min="0" />
                    <span asp-validation-for="TaxaJuros" class="text-danger"></span>
                </div>

                <div class="col-md-3">
                    <label asp-for="TempoMeses" class="form-label">Tempo (meses)</label>
                    <input asp-for="TempoMeses" class="form-control" type="number" min="1" />
                    <span asp-validation-for="TempoMeses" class="text-danger"></span>
                </div>

                @if (User.Identity?.IsAuthenticated ?? false)
                {
                    <div class="col-md-3">
                        <label asp-for="Descricao" class="form-label">Descrição (opcional)</label>
                        <input asp-for="Descricao" class="form-control" type="text" />
                    </div>
                }

                <div class="col-12">
                    @if (User.Identity?.IsAuthenticated ?? false)
                    {
                        <button type="submit" class="btn btn-primary">Calcular</button>
                    }
                    else
                    {
                        <button type="submit" class="btn btn-primary" disabled title="Faça login para simular">Calcular</button>
                    }
                </div>
            </form>
        </div>
    </div>

    @if (Model.HistoricoMeses?.Count > 0)
    {
        <!-- INTERFACE: cards com os resultados principais -->
        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="card text-bg-success h-100 shadow-sm">
                    <div class="card-body">
                        <h6 class="card-subtitle mb-2">💰 Total Acumulado</h6>
                        <h4 class="mb-0">@Model.MontanteFinal.ToString("C")</h4>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card text-bg-info h-100 shadow-sm">
                    <div class="card-body">
                        <h6 class="card-subtitle mb-2">📈 Total em Juros</h6>
                        <h4 class="mb-0">@Model.TotalJuros.ToString("C")</h4>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card text-bg-warning h-100 shadow-sm">
                    <div class="card-body">
                        <h6 class="card-subtitle mb-2">🎯 Rentabilidade (%)</h6>
                        <h4 class="mb-0">@Model.RentabilidadePercentual.ToString("N2")%</h4>
                    </div>
                </div>
            </div>
        </div>
    }

    <!--gráfico da evolução -->
    @if (Model.HistoricoMeses?.Count > 0)
    {
        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <h5 class="card-title">Evolução do investimento</h5>
                <canvas id="graficoInvestimento" height="100"></canvas>
            </div>
        </div>
    }

    @if (Model.ExtratoMeses?.Count > 0)
    {
        <!-- tabela detalhada mês a mês -->
        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <h5 class="card-title">Extrato mensal</h5>
                <div class="table-responsive">
                    <table class="table table-striped align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Mês</th>
                                <th>Juros Mensais</th>
                                <th>Saldo Acumulado</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.ExtratoMeses)
                            {
                                <tr>
                                    <td>@item.Mes</td>
                                    <td>@item.JurosMensais.ToString("C")</td>
                                    <td>@item.SaldoAcumulado.ToString("C")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    @if ((User.Identity?.IsAuthenticated ?? false) && Model.MinhasSimulacoes?.Count > 0)
    {
        <!-- Últimas simulações do usuário -->
        <div class="card shadow-sm">
            <div class="card-header">
                <h5 class="mb-0">Últimas Simulações</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-sm table-hover">
                        <thead>
                            <tr>
                                <th>Data</th>
                                <th>Valor Inicial</th>
                                <th>Taxa</th>
                                <th>Meses</th>
                                <th>Montante Final</th>
                                <th>Rentabilidade</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var sim in Model.MinhasSimulacoes.Take(5))
                            {
                                <tr>
                                    <td>@sim.DataSimulacao.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>R$ @sim.ValorInicial.ToString("F2")</td>
                                    <td>@sim.TaxaJuros.ToString("F2")%</td>
                                    <td>@sim.TempoMeses</td>
                                    <td>R$ @sim.MontanteFinal.ToString("F2")</td>
                                    <td>@sim.RentabilidadePercentual.ToString("F2")%</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <a asp-page="/Historico" class="btn btn-sm btn-outline-primary mt-2">Ver todas as simulações</a>
            </div>
        </div>
    }
</div>

<!-- API/BIBLIOTECA EXTERNA: Chart.js (via CDN) -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    // Dados vindos do back-end para montar o gráfico
    const historicoMeses = @Html.Raw(JsonSerializer.Serialize(Model.HistoricoMeses ?? new List<decimal>()));
    const labels = historicoMeses.map((_, index) => `Mês ${index + 1}`);

    const contexto = document.getElementById('graficoInvestimento');
    if (contexto) {
        new Chart(contexto, {
            type: 'line',
            data: {
                labels: labels,
                datasets: [{
                    label: 'Valor acumulado (R$)',
                    data: historicoMeses,
                    borderColor: 'rgb(13, 110, 253)',
                    backgroundColor: 'rgba(13, 110, 253, 0.2)',
                    tension: 0.25,
                    fill: true
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: {
                        display: true
                    }
                },
                scales: {
                    y: {
                        beginAtZero: false
                    }
                }
            }
        });
    }
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
